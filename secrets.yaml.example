# Copy this file to secrets.yaml and fill in your values.
# Do NOT commit secrets.yaml to version control.

wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"
wifi_fallback_password: "your-fallback-ap-password"
encryption_key: "generate-with: esphome wizard or openssl rand -base64 32"
ota_password: "your-ota-password"
